# Copy to .env for local development (never commit .env)

# Auth (REQUIRED)
# Generate: openssl rand -base64 32
AUTH_JWT_SECRET=<run: openssl rand -base64 32>

# Anthropic (REQUIRED for exam generation)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5
# Exam generation model (defaults to Sonnet; override if needed)
CLAUDE_EXAM_MODEL=claude-sonnet-4-20250514

# Supabase (REQUIRED for Google OAuth and email auth)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard ? Developers ? Webhooks ? add endpoint:
# https://lexicoil.com/.netlify/functions/stripe-webhook
# Event: checkout.session.completed

# Resend (optional ? Pro welcome email after payment)
RESEND_API_KEY=re_...
RESEND_FROM=LexiCoil <noreply@lexicoil.com>

# Admin (optional ? manual Pro activation for support)
ADMIN_SECRET=<run: openssl rand -base64 32>

# Site (use LEXICOIL_SITE_URL; LEXILOOP_SITE_URL is legacy fallback only)
LEXICOIL_SITE_URL=https://www.lexicoil.com
LEXICOIL_ALLOWED_ORIGINS=https://www.lexicoil.com,https://lexicoil.com
# LEXILOOP_SITE_URL=https://www.lexicoil.com

# Dev only ¯ remove in production
# ALLOW_NETLIFY_PREVIEWS=true
