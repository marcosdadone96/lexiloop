{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lexicoil.com/schemas/provider.schema.json",
  "title": "Provider Adapter Knowledge",
  "type": "object",
  "required": ["id", "name", "languageId", "levels"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "enum": ["goethe", "cambridge", "dele"] },
    "name": { "type": "string" },
    "languageId": { "type": "string", "enum": ["german", "english", "spanish"] },
    "levels": {
      "type": "object",
      "patternProperties": {
        "^(A1|A2|B1|B2|C1|C2)$": {
          "type": "object",
          "required": ["certificate", "modules", "taskTypes", "scoring"],
          "properties": {
            "certificate": { "type": "string" },
            "totalMinutes": { "type": "number" },
            "modules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "title", "minutes", "parts"],
                "properties": {
                  "id": { "type": "string" },
                  "title": { "type": "string" },
                  "minutes": { "type": "number" },
                  "parts": { "type": "number" }
                }
              }
            },
            "taskTypes": { "type": "object" },
            "scoring": { "type": "object" }
          }
        }
      }
    }
  }
}
